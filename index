<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Karchin Global S.R.L. – Premium Meat Exports from Romania</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Cormorant+Garamond:wght@300;400;600&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --crimson: #8B1A1A;
    --gold: #C9973A;
    --gold-light: #E8C06A;
    --cream: #FAF6EF;
    --dark: #1A1108;
    --charcoal: #2D2416;
    --mid: #5C4A2A;
    --border: rgba(201,151,58,0.25);
    --shadow: 0 20px 60px rgba(26,17,8,0.18);
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }
  body {
    background: var(--cream);
    color: var(--charcoal);
    font-family: 'Montserrat', sans-serif;
    overflow-x: hidden;
  }

  /* ── HEADER ── */
  header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(26,17,8,0.96);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 4rem;
    height: 72px;
  }
  .logo-area { display: flex; align-items: center; gap: 14px; }
  .logo-box {
    width: 46px; height: 46px;
    background: #fff;
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
  }
  .logo-box img { width: 100%; height: 100%; object-fit: contain; }
  .logo-text { display: flex; flex-direction: column; }
  .logo-name {
    font-family: 'Playfair Display', serif;
    font-weight: 700; font-size: 1.1rem;
    color: #fff;
    letter-spacing: 0.04em;
    line-height: 1;
  }
  .logo-sub {
    font-size: 0.6rem; color: var(--gold);
    letter-spacing: 0.15em; text-transform: uppercase; margin-top: 3px;
  }
  nav { display: flex; gap: 2rem; align-items: center; }
  nav a {
    color: rgba(255,255,255,0.75);
    text-decoration: none; font-size: 0.72rem;
    letter-spacing: 0.12em; text-transform: uppercase;
    transition: color 0.2s;
  }
  nav a:hover { color: var(--gold); }
  .nav-cta {
    background: var(--gold); color: var(--dark) !important;
    padding: 8px 20px; border-radius: 3px;
    font-weight: 600 !important;
    transition: background 0.2s !important;
  }
  .nav-cta:hover { background: var(--gold-light) !important; }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    background:
      linear-gradient(160deg, rgba(26,17,8,0.85) 0%, rgba(139,26,26,0.65) 50%, rgba(26,17,8,0.9) 100%),
      url('https://images.unsplash.com/photo-1560781290-7dc94c0f8f4f?w=1800&q=80') center/cover no-repeat;
    display: flex; align-items: center;
    padding: 0 8%;
    padding-top: 72px;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23C9973A' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }
  .hero-content { max-width: 700px; animation: fadeUp 1s ease both; }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(201,151,58,0.15);
    border: 1px solid var(--gold);
    color: var(--gold);
    padding: 6px 16px; border-radius: 2px;
    font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
    margin-bottom: 1.8rem;
    animation: fadeUp 1s ease 0.1s both;
  }
  .hero-badge::before { content: '★'; }
  h1.hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.8rem, 6vw, 5rem);
    font-weight: 900;
    color: #fff;
    line-height: 1.08;
    margin-bottom: 1.4rem;
    animation: fadeUp 1s ease 0.2s both;
  }
  h1.hero-title em { color: var(--gold); font-style: italic; }
  .hero-desc {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem; color: rgba(255,255,255,0.78);
    line-height: 1.7; max-width: 520px;
    margin-bottom: 2.4rem;
    animation: fadeUp 1s ease 0.3s both;
  }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; animation: fadeUp 1s ease 0.4s both; }
  .btn-primary {
    background: var(--gold); color: var(--dark);
    padding: 14px 32px; border: none; border-radius: 3px;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.72rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    cursor: pointer; text-decoration: none;
    transition: background 0.2s, transform 0.2s;
    display: inline-block;
  }
  .btn-primary:hover { background: var(--gold-light); transform: translateY(-2px); }
  .btn-outline {
    background: transparent; color: #fff;
    padding: 14px 32px; border: 1px solid rgba(255,255,255,0.4);
    border-radius: 3px;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.72rem; font-weight: 500;
    letter-spacing: 0.12em; text-transform: uppercase;
    cursor: pointer; text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
    display: inline-block;
  }
  .btn-outline:hover { border-color: var(--gold); color: var(--gold); transform: translateY(-2px); }

  .hero-stats {
    position: absolute; bottom: 3rem; right: 8%;
    display: flex; gap: 3rem;
    animation: fadeUp 1s ease 0.5s both;
  }
  .stat { text-align: center; }
  .stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 2.4rem; font-weight: 900;
    color: var(--gold); line-height: 1;
  }
  .stat-label {
    font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: rgba(255,255,255,0.55); margin-top: 4px;
  }

  /* ── SECTION SHARED ── */
  section { padding: 100px 8%; }
  .section-tag {
    font-size: 0.65rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 0.8rem;
    display: flex; align-items: center; gap: 10px;
  }
  .section-tag::after { content: ''; flex: 0 0 40px; height: 1px; background: var(--gold); }
  h2.section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900; line-height: 1.1;
    color: var(--dark);
    margin-bottom: 1.2rem;
  }
  .section-desc {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem; color: var(--mid);
    line-height: 1.75; max-width: 560px;
  }

  /* ── ABOUT ── */
  .about { background: var(--dark); }
  .about .section-tag { color: var(--gold); }
  .about h2.section-title { color: #fff; }
  .about .section-desc { color: rgba(255,255,255,0.65); max-width: 100%; }
  .about-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 5rem; align-items: center;
    margin-top: 3.5rem;
  }
  .about-visual {
    position: relative;
  }
  .about-img {
    width: 100%; aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid var(--border);
  }
  .about-badge {
    position: absolute; bottom: -1.5rem; right: -1.5rem;
    background: var(--gold);
    padding: 1.4rem 1.8rem;
    border-radius: 3px;
  }
  .about-badge-num {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem; font-weight: 900;
    color: var(--dark); line-height: 1;
  }
  .about-badge-txt {
    font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--dark); opacity: 0.75; margin-top: 3px;
  }
  .about-points { margin-top: 2rem; display: flex; flex-direction: column; gap: 1.2rem; }
  .about-point { display: flex; gap: 1rem; align-items: flex-start; }
  .about-point-icon {
    flex-shrink: 0;
    width: 36px; height: 36px;
    background: rgba(201,151,58,0.12);
    border: 1px solid var(--border);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem;
  }
  .about-point-text { color: rgba(255,255,255,0.75); font-size: 0.88rem; line-height: 1.65; }
  .about-point-text strong { color: var(--gold); }

  /* ── PRODUCTS ── */
  .products { background: var(--cream); }
  .products-header { text-align: center; margin-bottom: 3.5rem; }
  .products-header .section-tag { justify-content: center; }
  .products-header .section-tag::after { display: none; }
  .products-header .section-desc { margin: 0 auto; text-align: center; }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }
  .product-card {
    background: #fff;
    overflow: hidden;
    cursor: pointer;
    position: relative;
  }
  .product-card:first-child { grid-column: span 2; }
  .product-img {
    width: 100%;
    height: 340px;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .product-card:first-child .product-img { height: 480px; }
  .product-card:hover .product-img { transform: scale(1.04); }
  .product-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(26,17,8,0.88) 100%);
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 2rem;
    pointer-events: none;
  }
  .product-cat {
    font-size: 0.6rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 0.4rem;
  }
  .product-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem; font-weight: 700;
    color: #fff; margin-bottom: 0.3rem;
  }
  .product-detail { font-size: 0.78rem; color: rgba(255,255,255,0.65); }

  /* Second row */
  .products-row2 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 2px;
  }
  .products-row2 .product-img { height: 300px; }

  /* ── QUALITY ── */
  .quality {
    background: linear-gradient(135deg, var(--charcoal) 0%, var(--dark) 100%);
    position: relative; overflow: hidden;
  }
  .quality::before {
    content: '';
    position: absolute;
    top: -50%; right: -20%;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(201,151,58,0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .quality-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 5rem; align-items: center;
  }
  .quality h2.section-title { color: #fff; }
  .quality .section-desc { color: rgba(255,255,255,0.65); }
  .quality-grades { margin-top: 2.5rem; display: flex; flex-direction: column; gap: 1rem; }
  .grade-row {
    display: flex; align-items: center; gap: 1.2rem;
    padding: 1rem 1.2rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: rgba(255,255,255,0.03);
    transition: background 0.2s;
  }
  .grade-row:hover { background: rgba(201,151,58,0.07); }
  .grade-badge {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem; font-weight: 900;
    color: var(--gold); min-width: 50px; text-align: center;
  }
  .grade-info strong { display: block; color: #fff; font-size: 0.85rem; margin-bottom: 2px; }
  .grade-info span { color: rgba(255,255,255,0.55); font-size: 0.78rem; }

  .quality-features {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;
  }
  .feat-box {
    padding: 1.5rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    border-radius: 4px;
    text-align: center;
    transition: background 0.2s, transform 0.2s;
  }
  .feat-box:hover { background: rgba(201,151,58,0.07); transform: translateY(-3px); }
  .feat-icon { font-size: 2rem; margin-bottom: 0.7rem; }
  .feat-title { color: var(--gold); font-size: 0.8rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.4rem; }
  .feat-desc { color: rgba(255,255,255,0.55); font-size: 0.78rem; line-height: 1.6; }

  /* ── SPECS ── */
  .specs { background: var(--cream); }
  .specs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-top: 3rem; }
  .spec-card {
    background: #fff;
    border: 1px solid rgba(201,151,58,0.15);
    border-radius: 6px;
    padding: 2rem;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .spec-card:hover { box-shadow: var(--shadow); transform: translateY(-4px); }
  .spec-icon { font-size: 2.5rem; margin-bottom: 1rem; }
  .spec-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem; font-weight: 700;
    color: var(--dark); margin-bottom: 0.6rem;
  }
  .spec-list { list-style: none; }
  .spec-list li {
    display: flex; align-items: flex-start; gap: 8px;
    font-size: 0.82rem; color: var(--mid);
    padding: 5px 0; border-bottom: 1px solid #f0ebe0;
    line-height: 1.5;
  }
  .spec-list li::before { content: '▸'; color: var(--gold); flex-shrink: 0; margin-top: 1px; }

  /* ── INQUIRY FORM ── */
  .inquiry {
    background: var(--dark);
    position: relative; overflow: hidden;
  }
  .inquiry::after {
    content: 'KG';
    position: absolute; right: -2%; bottom: -5%;
    font-family: 'Playfair Display', serif;
    font-size: 22vw; font-weight: 900;
    color: rgba(201,151,58,0.04);
    line-height: 1; pointer-events: none; user-select: none;
  }
  .inquiry-inner {
    display: grid; grid-template-columns: 1fr 1.5fr;
    gap: 5rem; align-items: start;
  }
  .inquiry h2.section-title { color: #fff; }
  .inquiry .section-desc { color: rgba(255,255,255,0.6); }
  .inquiry-info { margin-top: 2rem; display: flex; flex-direction: column; gap: 1.2rem; }
  .info-row { display: flex; gap: 1rem; align-items: flex-start; }
  .info-icon { font-size: 1.2rem; flex-shrink: 0; margin-top: 2px; }
  .info-text strong { display: block; color: var(--gold); font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 2px; }
  .info-text span { color: rgba(255,255,255,0.65); font-size: 0.85rem; }

  .form-card {
    background: #fff;
    border-radius: 6px;
    padding: 2.5rem;
    box-shadow: var(--shadow);
  }
  .form-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem; font-weight: 700;
    color: var(--dark); margin-bottom: 0.3rem;
  }
  .form-subtitle { font-size: 0.8rem; color: var(--mid); margin-bottom: 1.8rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
  .form-group { display: flex; flex-direction: column; gap: 5px; margin-bottom: 1rem; }
  .form-group label {
    font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--charcoal); font-weight: 600;
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 10px 14px;
    border: 1.5px solid #e0d9cc;
    border-radius: 4px;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.85rem; color: var(--dark);
    background: #FDFBF8;
    transition: border-color 0.2s;
    outline: none;
    appearance: none;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus { border-color: var(--gold); }
  .form-group textarea { resize: vertical; min-height: 90px; }

  .checkbox-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 0.5rem; margin-top: 0.3rem;
  }
  .checkbox-item {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.8rem; color: var(--charcoal); cursor: pointer;
  }
  .checkbox-item input[type="checkbox"] {
    width: 15px; height: 15px;
    accent-color: var(--crimson);
    cursor: pointer;
    padding: 0; border: none;
  }
  .form-submit {
    width: 100%;
    background: var(--crimson); color: #fff;
    padding: 14px; border: none; border-radius: 4px;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.78rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    margin-top: 0.5rem;
  }
  .form-submit:hover { background: #6E1414; transform: translateY(-2px); }

  .success-msg {
    display: none;
    text-align: center; padding: 2rem;
    background: #f0fbf0; border: 1px solid #b0ddb0;
    border-radius: 4px; margin-top: 1rem;
    color: #1a5c1a; font-size: 0.9rem; line-height: 1.6;
  }
  .success-msg .checkmark { font-size: 2.5rem; display: block; margin-bottom: 0.5rem; }

  /* ── FOOTER ── */
  footer {
    background: #0f0a04;
    color: rgba(255,255,255,0.5);
    padding: 3rem 8% 2rem;
  }
  .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 3rem; margin-bottom: 2.5rem; }
  .footer-brand .logo-name { font-size: 1.4rem; margin-bottom: 0.4rem; }
  .footer-brand p { font-size: 0.8rem; line-height: 1.7; max-width: 300px; margin-top: 0.8rem; }
  .footer-col h4 {
    color: var(--gold); font-size: 0.65rem;
    letter-spacing: 0.18em; text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .footer-col a, .footer-col p {
    display: block; color: rgba(255,255,255,0.5);
    text-decoration: none; font-size: 0.8rem;
    margin-bottom: 0.5rem; transition: color 0.2s;
    line-height: 1.6;
  }
  .footer-col a:hover { color: var(--gold); }
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: 1.5rem;
    display: flex; justify-content: space-between; align-items: center;
    font-size: 0.72rem;
  }
  .footer-bottom span { color: var(--gold); }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    header { padding: 0 1.5rem; }
    nav { display: none; }
    section { padding: 70px 5%; }
    .hero { padding: 0 5%; padding-top: 72px; }
    .about-grid, .quality-grid, .inquiry-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .products-grid, .products-row2 { grid-template-columns: 1fr; }
    .product-card:first-child { grid-column: span 1; }
    .specs-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
    .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
    .hero-stats { position: static; margin-top: 2.5rem; justify-content: flex-start; }
    .about-badge { display: none; }
    .quality-features { grid-template-columns: 1fr 1fr; }
  }
</style>
</head>
<body>

<!-- HEADER -->
<header>
  <div class="logo-area">
    <div class="logo-box">
      <!-- KG Logo recreation using text/SVG since it's a black bg with KG initials -->
      <svg viewBox="0 0 46 46" xmlns="http://www.w3.org/2000/svg" width="46" height="46">
        <rect width="46" height="46" fill="#111"/>
        <!-- Crown -->
        <polygon points="10,18 15,10 23,15 31,10 36,18" fill="white" stroke="none"/>
        <circle cx="10" cy="18" r="2" fill="white"/>
        <circle cx="23" cy="14" r="2" fill="white"/>
        <circle cx="36" cy="18" r="2" fill="white"/>
        <!-- Shield shape -->
        <path d="M12 19 L34 19 L34 30 L23 38 L12 30 Z" fill="none" stroke="white" stroke-width="2"/>
        <!-- KG text -->
        <text x="13" y="31" font-family="Arial Black" font-size="9" fill="white" font-weight="900">KG</text>
      </svg>
    </div>
    <div class="logo-text">
      <span class="logo-name">Karchin Global</span>
      <span class="logo-sub">S.R.L. · Romania</span>
    </div>
  </div>
  <nav>
    <a href="#about">About</a>
    <a href="#products">Products</a>
    <a href="#quality">Quality</a>
    <a href="#specs">Specifications</a>
    <a href="#inquiry" class="nav-cta">Get a Quote</a>
  </nav>
</header>

<!-- HERO -->
<section class="hero" id="home">
  <div class="hero-content">
    <div class="hero-badge">Romania's Premier Meat Exporter</div>
    <h1 class="hero-title">
      Premium Quality<br><em>Meat Exports</em><br>From the Heart of Romania
    </h1>
    <p class="hero-desc">
      Supplying the finest sheep, beef, offals and salted casings to global markets. 
      Fully Halal certified, fresh-frozen in 40ft FCL containers worldwide.
